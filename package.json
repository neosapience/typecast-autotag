{
  "name": "typecast-autotag",
  "version": "1.1.0",
  "private": true,
  "description": "Text preprocessing SDK for Typecast TTS API - automatically converts phone numbers, dates, names, and other patterns into speech-friendly formats for AICC environments",
  "source": "src/index.ts",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "microbundle --tsconfig tsconfig.build.json",
    "dev": "microbundle watch --tsconfig tsconfig.build.json",
    "test": "jest && pnpm test:e2e",
    "test:jest": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "pnpm c-binding:bundle && pnpm c-binding:build-linux && tsx c-binding/scripts/e2e/index.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "setup": "pnpm install && pnpm build && pnpm c-binding:all",
    "c-binding:duktape": "cd c-binding && make duktape",
    "c-binding:bundle": "node c-binding/scripts/bundle.js",
    "c-binding:build": "cd c-binding && make",
    "c-binding:build-linux": "cd c-binding && docker build -t typecast-autotag-builder -f Dockerfile.build . && docker run --rm -v $(pwd)/build:/output typecast-autotag-builder",
    "c-binding:all": "pnpm c-binding:duktape && pnpm c-binding:bundle && pnpm c-binding:build",
    "c-binding:example": "cd c-binding && make example",
    "c-binding:test": "cd c-binding && make test",
    "c-binding:clean": "cd c-binding && make clean",
    "c-binding:distclean": "cd c-binding && make distclean"
  },
  "keywords": [
    "typecast",
    "tts",
    "text-to-speech",
    "aicc",
    "ivr",
    "korean",
    "text-preprocessing",
    "phone-number",
    "date-format"
  ],
  "author": "typecast",
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "esbuild": "^0.27.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.11",
    "microbundle": "^0.15.1",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "zx": "^8.8.5"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.15.2"
}
